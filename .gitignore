/.servo
/.cargo/*
!/.cargo/config.*
# cargo-check / reftest log artifacts (root + per-crate, any depth): test
# outputs, reftest dumps, pass/fail lists. The committed cargo-check-env.ps1
# (mozjs build-env script) is the one thing kept.
**/.cargo-check-logs/**
!**/.cargo-check-logs/cargo-check-env.ps1
# WPT run logs (per-port, any depth): local test output, never committed.
**/.wpt-logs/
/.rustup
/.servobuild
/.wpt
/.vs
/android-toolchains
/target
# Sub-workspace build outputs. Each of these crates has its own
# [workspace], so the root `/target` (anchored) doesn't cover them.
# Explicit paths on purpose: a blanket `target/` would also ignore the
# tracked WPT test resource at
# tests/wpt/.../the-form-element/resources/target (a real test dir, not
# build output).
/components/script-engine-boa/target
/probes/*/target
/tests/wpt/reftests-report/report.html
/python/_virtualenv*
/python/_venv*
/python/tidy/servo_tidy.egg-info
/tests/wpt/sync
/tests/wpt/**/**/.cache/
/tests/dromaeo/dromaeo
*.pkl
*.pyc
*.swp
*.swo
*.csv
*.rej
*.orig
.coverage
.DS_Store
Servo.app
servo.pftrace
.config.mk.last
/glfw
webrender-captures/
/screenshots
/etc/notarization/

# Python setuptools
/servo.egg-info

# Allow CSV files to be used as resources in tests
!/tests/**/*.csv

