Session.vim
Sessionx.vim

# Zed
/.zed

/unminified-js
/unminified-css

# Layout debugger trace files
layout_trace*

# Package managers
support/macos/Brewfile.lock.json

# direnv
.envrc

# Justfiles
justfile

# sem (Ataraxy-Labs) semantic-diff index cache — local, never committed.
.sem/

# Claude Code session state: worktrees, hooks, agent transcripts.
.claude/
